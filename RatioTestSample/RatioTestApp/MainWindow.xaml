<Window x:Class="RatioTestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RatioTestApp"
        mc:Ignorable="d"
        Title="Ratio Test App" Height="450" Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Settings header -->
        <Label Grid.Row="0" Grid.Column="0"
               FontSize="14"
               VerticalAlignment="Center"
               Content="SETTINGS" />

        <!-- Test Voltage -->
        <Label Grid.Row="1" Grid.Column="0"
               VerticalAlignment="Center"
               Content="Test voltage (V):" />
        <TextBox Grid.Row="1" Grid.Column="1" Margin="5,0,0,4"
                 x:Name="TestVoltageTextBox"
                 AutomationProperties.AutomationId="TestVoltageTextBox"
                 Width="120"
                 Text="5" />

        <!-- Nameplate Data header -->
        <Label Grid.Row="2" Grid.Column="0"
               VerticalAlignment="Center"
               FontWeight="Bold"
               Content="Nameplate Data" />

        <!-- Primary Rated Voltage -->
        <Label Grid.Row="3" Grid.Column="0"
               VerticalAlignment="Center"
               Content="Primary Rated Voltage (V):" />
        <TextBox Grid.Row="3" Grid.Column="1" Margin="5,0,0,4"
                 x:Name="RatedPrimaryVoltageTextBox"
                 AutomationProperties.AutomationId="RatedPrimaryVoltageTextBox"
                 Width="120"
                 Text="" />

        <!-- Secondary Rated Voltage -->
        <Label Grid.Row="3" Grid.Column="4"
               VerticalAlignment="Center"
               Content="Secondary Rated Voltage (V):" />
        <TextBox Grid.Row="3" Grid.Column="5" Margin="5,0,0,4"
                 x:Name="RatedSecondaryVoltageTextBox"
                 AutomationProperties.AutomationId="RatedSecondaryVoltageTextBox"
                 Width="120"
                 Text="" />

        <!-- Run Measurement button -->
        <Button Grid.Row="4" Grid.ColumnSpan="2" Margin="0,8,0,8"
                x:Name="RunMeasurementButton"
                AutomationProperties.AutomationId="RunMeasurementButton"
                Content="Run Measurement"
                Width="160"
                HorizontalAlignment="Left"
                Click="RunMeasurementButton_OnClick" />

        <!-- Results header -->
        <Label Grid.Row="5" Grid.Column="0"
               FontSize="14"
               VerticalAlignment="Center"
               Content="RESULTS" />

        <!-- Results panel -->
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Vertical">
            <TextBlock x:Name="MeasuredPrimaryVoltageTextBlock"
                       AutomationProperties.AutomationId="MeasuredPrimaryVoltageTextBlock"
                       Margin="0,0,0,2" />
            <TextBlock x:Name="MeasuredPrimaryCurrentTextBlock"
                       AutomationProperties.AutomationId="MeasuredPrimaryCurrentTextBlock"
                       Margin="0,0,0,2" />
            <TextBlock x:Name="MeasuredSecondaryVoltageTextBlock"
                       AutomationProperties.AutomationId="MeasuredSecondaryVoltageTextBlock"
                       Margin="0,0,0,2" />
            <TextBlock x:Name="ExpectedVoltageRatioTextBlock"
                       AutomationProperties.AutomationId="ExpectedVoltageRatioTextBlock"
                       FontWeight="Bold"
                       Margin="0,4,0,2" />
            <TextBlock x:Name="VoltageRatioTextBlock"
                       AutomationProperties.AutomationId="VoltageRatioTextBlock"
                       FontWeight="Bold"
                       Margin="0,4,0,2" />
            <TextBlock x:Name="RatioDeviationTextBlock"
                       AutomationProperties.AutomationId="RatioDeviationTextBlock"
                       FontWeight="Bold"
                       Margin="0,4,0,2" />
            <TextBlock x:Name="ErrorTextBlock"
                       AutomationProperties.AutomationId="ErrorTextBlock"
                       Foreground="Red"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Grid>
</Window>
